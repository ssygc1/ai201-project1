# Copy this file to .env and replace the placeholders with your actual keys.
# .env is listed in .gitignore — never commit your real keys.
#
# Get a free Groq API key (no credit card required) at:
# https://console.groq.com
#
# Get a Yelp Fusion API key at:
# https://fusion.yelp.com

GROQ_API_KEY=your_groq_key_here
YELP_API_KEY=your_yelp_key_here
